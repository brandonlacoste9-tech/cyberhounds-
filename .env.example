# 🐺 CYBERHOUND ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values

# ============================================
# TELEGRAM HOTL (Human-on-the-Loop)
# Get bot token from @BotFather: https://t.me/botfather
# Get chat ID: https://t.me/userinfobot
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# SCRAPING CONFIGURATION
# ============================================
# Delay between HTTP requests (seconds)
# Higher = more polite, slower
# Lower = faster, risk of being blocked
RATE_LIMIT_DELAY=1.0

# Number of retries for failed requests
MAX_RETRIES=3

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# ============================================
# CRON/LOOP SETTINGS
# ============================================
# Seconds between hunt cycles (default: 1800 = 30 minutes)
CYCLE_INTERVAL=1800

# Maximum runtime for a single hunt (seconds)
MAX_HUNT_RUNTIME=1800

# ============================================
# ALERTS & MONITORING
# ============================================
# Webhook URL for failure alerts (Slack, Discord, etc.)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email for alerts (if using email notifier)
# ALERT_EMAIL=admin@yourcompany.com

# ============================================
# DATABASE (Optional - defaults to JSON files)
# ============================================
# DATABASE_URL=postgresql://user:pass@localhost/cyberhound

# ============================================
# PROXY CONFIGURATION (Optional)
# ============================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ============================================
# ADVANCED
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Data directory path (default: hound_core/data)
# DATA_DIR=/path/to/custom/data
